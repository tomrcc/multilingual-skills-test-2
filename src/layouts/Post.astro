---
import Layout from "./Layout.astro";
import PostSummary from "../components/blog/summary.astro";
import PostHero from "../components/blog/post-hero/post-hero.astro";
import { getCollection } from "astro:content";
import { blogCollectionName, localePrefix, dateLocaleFor } from "../lib/i18n";

type Props = {
  frontmatter: {
    title: string;
    post_hero: {
      heading: string;
      date: string | Date;
      image: string;
      image_alt: string;
      author: string;
      tags: Array<string>;
    };
  };
  body: string;
  locale?: string;
};

const { frontmatter, body, locale } = Astro.props;

const prefix = localePrefix(locale);
const dateLocale = dateLocaleFor(locale);

const posts = await getCollection(blogCollectionName(locale) as any);
const filteredPosts = posts.filter(
  (post) => post.data.title !== frontmatter.title,
);

// Align the Rosey root with the English-equivalent path so shared-UI keys on
// locale pages resolve against the base-language keys (strip the locale prefix).
const rawRoot = Astro.url.pathname.replace(/^\/|\/$/g, "");
const roseyRoot =
  locale && rawRoot.startsWith(`${locale}/`)
    ? rawRoot.slice(locale.length + 1)
    : rawRoot;
---

<Layout {...frontmatter} roseyRoot={roseyRoot}>
  <div class="mx-auto max-w-3xl px-8 py-12 md:py-20">
    <article>
      <editable-component data-prop="post_hero" data-component="PostHero">
        <PostHero
          {...frontmatter.post_hero}
          bodyContent={body}
          localePrefix={prefix}
          dateLocale={dateLocale}
        />
      </editable-component>
      <div class="prose" data-pagefind-body>
        <editable-text data-prop="@content" data-type="block">
          <slot />
        </editable-text>
      </div>
    </article>
  </div>

  {
    filteredPosts.length > 0 && (
      <section class="mx-auto max-w-6xl px-8 pb-16" data-rosey-root="blog">
        <h2 class="text-2xl font-bold mb-6" data-rosey="recent_posts">Recent Posts</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
          {filteredPosts.slice(0, 3).map((post) => (
            <li>
              <PostSummary
                {...post}
                loading="lazy"
                localePrefix={prefix}
                dateLocale={dateLocale}
              />
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
