---
import site from "data/site.json";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

interface Props {
  heading: string;
  date: string | Date;
  author: string;
  image: string;
  image_alt: string;
  tags: Array<string>;
  bodyContent: string;
  localePrefix?: string;
  dateLocale?: string;
}

const {
  heading,
  date,
  author,
  image,
  image_alt,
  tags,
  bodyContent,
  localePrefix = "",
  dateLocale,
} = Astro.props;

const wordCount = bodyContent?.split(" ")?.length ?? 0;
const dateObj = new Date(date);
const authorWithFallback = author || site.default_author;

const readingTimeInMins = Math.floor(wordCount / 183);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg,avif,webp}",
  { eager: true },
);
const imageSrc = images[image]?.default || image;
---

<div class="flex flex-col">
  {
    image && image_alt && (
      <Picture
        data-editable="image"
        data-prop-src="image"
        data-prop-alt="image_alt"
        class="w-full rounded-lg aspect-video object-cover"
        src={imageSrc}
        alt={image_alt}
        widths={[600, 800, 1200]}
        sizes="(max-width: 1200px) 100vw, 1200px"
        loading="eager"
        formats={["avif", "webp"]}
      />
    )
  }
  <h1
    data-editable="text"
    data-prop="heading"
    class="text-3xl md:text-4xl font-bold mt-4 mb-2 text-balance">
    {heading}
  </h1>
  {
    tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 my-2">
        {tags.map((tag: string) => (
          <a
            href={`${localePrefix}/tags/${tag}/`}
            class="bg-gray-100 text-blue-600 text-xs font-medium px-3 py-1 rounded-md no-underline">
            {tag.charAt(0).toUpperCase() + tag.slice(1)}
          </a>
        ))}
      </div>
    )
  }
  <div class="flex flex-col gap-1 py-4 text-sm text-gray-500" data-rosey-root="blog">
    <p data-editable="text" data-prop="author">{authorWithFallback}</p>
    {
      dateObj && (
        <p>
          {dateObj.toLocaleDateString(dateLocale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
      )
    }
    <p>
      {wordCount} <span data-rosey="words">words</span> &middot;{" "}
      {readingTimeInMins < 1 ? (
        <span data-rosey="reading_time_under_minute">Less than a minute</span>
      ) : (
        <span>
          {readingTimeInMins} <span data-rosey="reading_time_unit">min read</span>
        </span>
      )}
    </p>
  </div>
</div>
